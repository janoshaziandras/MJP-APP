@page "/stats"
@using MJP_APP.Client.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Globális Statisztika</PageTitle>

<div class="container mt-4">
    <div class="text-start mb-3">
        <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/", forceLoad: true)'>&larr; Vissza a menübe</button>
    </div>

    <h2 class="mb-4 text-center">🏆 Játékonkénti Ranglisták</h2>

    @if (gameStats == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (gameStats.Count == 0)
    {
        <div class="alert alert-info text-center">Még senki sem játszott. Legyél te az első!</div>
    }
    else
    {
        @foreach (var game in gameStats)
        {
            <div class="mb-5">
                <h3 class="text-center mb-3">@game.Key</h3>
                <div class="table-responsive shadow-sm rounded">
                    <table class="table table-hover table-striped text-center align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Helyezés</th>
                                <th>Játékos</th>
                                <th>Pontszám</th>
                                <th>Idő (mp)</th>
                                <th>Dátum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in game.Value.Select((s, i) => new { Stat = s, Index = i + 1 }))
                            {
                                <tr>
                                    <td class="fw-bold">@stat.Index</td>
                                    <td class="fw-bold text-primary">@stat.Stat.UserName</td>
                                    <td class="fw-bold fs-5">@stat.Stat.Score</td>
                                    <td>@stat.Stat.DurationSeconds</td>
                                    <td class="small text-muted">@stat.Stat.Date.ToString("yyyy. MM. dd. HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private Dictionary<string, List<StatRecord>>? gameStats;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Lekérjük az adatbázisból a ranglistát
            var allStats = await Http.GetFromJsonAsync<List<StatRecord>>("/api/stats");
            if (allStats != null)
            {
                gameStats = allStats.Where(s => s.GameName != "Relaxacio")
                                    .GroupBy(s => s.GameName)
                                    .ToDictionary(g => g.Key, g => g.OrderByDescending(s => s.Score).Take(10).ToList());
            }
            else
            {
                gameStats = new Dictionary<string, List<StatRecord>>();
            }
        }
        catch
        {
            gameStats = new Dictionary<string, List<StatRecord>>();
        }
    }
}